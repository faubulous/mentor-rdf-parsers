{
  "name": "@faubulous/mentor-rdf-parsers",
  "description": "Chevrotain parsers for RDF languages such as N-Triples, N-Quads, Turtle and Trig.",
  "keywords": [
    "rdf",
    "parser",
    "turtle",
    "n3",
    "typescript",
    "chevrotain"
  ],
  "version": "1.7.4",
  "private": false,
  "author": {
    "name": "Sebastian Faubel"
  },
  "license": "LGPL-2.1-or-later",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faubulous/mentor-rdf-parsers.git"
  },
  "bugs": {
    "url": "https://github.com/faubulous/mentor-rdf-parsers/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench --run",
    "bench:stable": "vitest bench --run",
    "bench:baseline": "node scripts/run-bench-baseline.mjs",
    "bench:watch": "vitest bench",
    "build": "tsc",
    "check:pack": "npm pack --dry-run",
    "ci:quality": "npm run typecheck && npm test && npm run build && npm run check:pack",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rdfjs/data-model": "^2.1.1",
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/rdfjs__data-model": "^2.0.9",
    "@vitest/coverage-v8": "^4.1.5",
    "command-line-args": "^6.0.2",
    "n3": "^2.0.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
